#include <stdio.h>

int main()
{
    char str[200];
    int i = 0;

    printf("Enter the program:\n");
    fgets(str, 200, stdin);

    while(str[i] != '\0')
    {
        // Ignore spaces, tabs and new lines
        if(str[i] == ' ' || str[i] == '\t' || str[i] == '\n')
        {
            i++;
            continue;
        }

        // Ignore single line comment
        if(str[i] == '/' && str[i+1] == '/')
        {
            break;
        }

        // Ignore multi line comment
        if(str[i] == '/' && str[i+1] == '*')
        {
            i += 2;
            while(!(str[i] == '*' && str[i+1] == '/'))
                i++;
            i += 2;
            continue;
        }

        printf("%c", str[i]);
        i++;
    }

    return 0;
}

